# ===== 云端 LLM API（公开任务）=====
# DeepSeek（推荐，中文医学表现好、价格低）
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 可选：OpenAI 兼容备用
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 本地 LLM（敏感任务，经 Ollama）=====
# 本机已有 qwen3.5:9b；如需更强可 `ollama pull qwen2.5:14b`
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=qwen3.5:9b

# ===== Embedding（中文文献向量化）=====
EMBEDDING_MODEL=BAAI/bge-m3

# ===== 外部检索 =====
# PubMed 需要邮箱（NCBI Entrez 要求），可选 API key 提高频率
PUBMED_EMAIL=your_email@example.com
PUBMED_API_KEY=

# ===== RAG =====
CHROMA_DIR=./data/chroma

# ===== 全本地模式 =====
# 未配置云端 key 时设 true，所有任务走本地 Ollama（便于离线 demo）；
# 配好 DeepSeek key 后设 false 启用混合部署。
ALL_LOCAL=true

# ===== MySQL 与认证 =====
# 请先在本地 MySQL 创建 hnmu_agent 数据库和专用用户。
DATABASE_URL=mysql+pymysql://hnmu_agent:change-me@127.0.0.1:3306/hnmu_agent?charset=utf8mb4
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=1440
